# Monerium App Configuration
# Create an OAuth application at https://sandbox.monerium.dev to get your Client ID
MONERIUM_CLIENT_ID=your_client_id_here
MONERIUM_REDIRECT_URI=http://localhost:5001/dashboard
MONERIUM_APP_DOMAIN=localhost:5001
MONERIUM_APP_NAME="SDK TEST APP"
MONERIUM_PRIVACY_POLICY_URL=https://monerium.com/policies/privacy-policy
MONERIUM_TOS_URL=https://monerium.com/policies/personal-terms-of-service
